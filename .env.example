# =============================================================================
# Subscription Watchdog — Environment Variables Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY (PRD Section 9): Never commit .env to version control.
# The .gitignore file excludes it automatically.
# =============================================================================

# --- Google Gemini API Key ---
# Required for the Scanner Agent (email extraction) and Drafting Agent
# (email generation). Get one from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Groq API Key ---
# Optional: If you prefer to use Groq LLM services (Llama-3) instead of Google Gemini.
# Get one from: https://console.groq.com/
GROQ_API_KEY=

# --- Gmail OAuth Credentials ---
# Path to the OAuth client credentials JSON file downloaded from the
# Google Cloud Console. Required for Gmail MCP server.
# See: https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# --- Google Calendar OAuth Credentials ---
# Uses the same credentials.json as Gmail but stores a separate token
# to maintain clean scope separation (PRD Section 9).
CALENDAR_CREDENTIALS_PATH=credentials.json
CALENDAR_TOKEN_PATH=calendar_token.json
